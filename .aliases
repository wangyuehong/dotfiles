alias e='emacs -nw'
alias cc='claude'
alias cc2='CLAUDE_CODE_DISABLE_1M_CONTEXT=1 claude'
alias ec='emacsclient -t'
alias n='nvim'
alias v='vim'
alias ..='cd ..'
alias ...='cd ../..'
alias g='git'
alias df='df -h'
alias du='du -h'
alias su="su -"
alias sudo='sudo -E'
alias less='less -r'
alias tree='tree -C'
alias ll='ls -l'
alias tq='tmux new -A -s quick'
